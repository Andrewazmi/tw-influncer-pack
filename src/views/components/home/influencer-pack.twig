{#
| Variable                           | Type       | Description
|------------------------------------|------------|---------------------------------------------
| component                          | object     | Component settings from twilight.json
| component.creators                 | object[]   | Creator cards collection
| component.reels                    | object[]   | Reels collection
| component.promo_blocks             | object[]   | Promo blocks collection
| component.picked_products          | Product[]  | Selected products
| position                           | int        | Component order on home page
#}
{% set block_id = 'influencer-pack-' ~ position %}
{% set creators = component.creators|default([]) %}
{% set creators_count = creators|length %}
{% set reels = component.reels|default([]) %}
{% set promo_blocks = component.promo_blocks|default([]) %}
{% set picked_products = component.picked_products|default([]) %}
{% set show_creators = component.show_creators|default(true) and creators|length %}
{% set show_reels = component.show_reels|default(true) and reels|length %}
{% set show_promo_blocks = component.show_promo_blocks|default(true) and promo_blocks|length %}
{% set show_picked_products = component.show_picked_products|default(true) and picked_products|length %}
{% set autoplay_enabled = component.reels_autoplay|default(true) %}
{% set muted_enabled = component.reels_muted is same as(false) ? false : true %}
{% set section_title = component.title|default('') %}
{% set section_subtitle = component.subtitle|default('') %}
{% set copy_button_text = component.copy_code_button_text|default('نسخ الكود') %}
{% if copy_button_text is iterable %}
  {% set copy_button_text = copy_button_text.ar|default(copy_button_text.en|default(copy_button_text|first|default('نسخ الكود'))) %}
{% endif %}
{% if not copy_button_text or copy_button_text == 'Copy code' %}
  {% set copy_button_text = 'نسخ الكود' %}
{% endif %}
{% set copy_button_color = component.copy_code_button_color|default('#111111') %}
{% set creators_aria_label = 'المؤثرون' %}
{% set promo_aria_label = trans('pages.offers.title') %}
{% if promo_aria_label == 'pages.offers.title' %}
  {% set promo_aria_label = 'عروض الخصم' %}
{% endif %}

<section
  id="{{ block_id }}"
  class="s-block s-block--influencer-pack"
  data-autoplay="{{ autoplay_enabled ? 'true' : 'false' }}"
  data-muted="{{ muted_enabled ? 'true' : 'false' }}"
  data-copy-button-color="{{ copy_button_color }}">
  <div class="container">
    {% if section_title or section_subtitle %}
      <header class="influencer-pack__header">
        {% if section_title %}
          <h2 class="influencer-pack__title">{{ section_title }}</h2>
        {% endif %}
        {% if section_subtitle %}
          <p class="influencer-pack__subtitle">{{ section_subtitle }}</p>
        {% endif %}
      </header>
    {% endif %}

    {% if show_creators %}
      <div
        class="influencer-pack__creators"
        role="list"
        aria-label="{{ creators_aria_label }}">
        {% for creator in creators %}
          {% set profile_url = creator.profile_url|default('') %}
          {% if profile_url is iterable %}
            {% set profile_url_item = profile_url|first %}
            {% if profile_url_item is iterable %}
              {% set profile_url = profile_url_item.value|default('') %}
            {% else %}
              {% set profile_url = profile_url_item|default('') %}
            {% endif %}
          {% endif %}
          {% set creator_name = creator.name|default('') %}
          <article class="influencer-pack__creator" role="listitem">
            <div class="influencer-pack__creator-card">
              {% if profile_url %}
                <a href="{{ profile_url }}" class="influencer-pack__creator-link" aria-label="{{ creator_name ? creator_name : 'Creator Profile' }}">
              {% else %}
                <div class="influencer-pack__creator-link">
              {% endif %}
                <span class="influencer-pack__creator-avatar">
                  {% if creator.avatar %}
                    <img src="{{ creator.avatar }}" alt="{{ creator_name ? creator_name : 'Creator avatar' }}" loading="lazy">
                  {% endif %}
                </span>
                <span class="influencer-pack__creator-meta">
                  {% if creator_name %}
                    <strong class="influencer-pack__creator-name">{{ creator_name }}</strong>
                  {% endif %}
                  {% if creator.handle %}
                    <span class="influencer-pack__creator-handle" dir="ltr">{{ creator.handle }}</span>
                  {% endif %}
                </span>
              {% if profile_url %}
                </a>
              {% else %}
                </div>
              {% endif %}
              {% if creator.promo_code %}
                <span class="influencer-pack__code-group influencer-pack__code-group--creator">
                  <span class="influencer-pack__creator-code" dir="ltr">{{ creator.promo_code }}</span>
                  <button type="button" class="influencer-pack__copy-code" data-code="{{ creator.promo_code|e('html_attr') }}">{{ copy_button_text }}</button>
                </span>
              {% endif %}
            </div>
          </article>
        {% endfor %}
      </div>
    {% endif %}

    {% if show_reels %}
      <section class="influencer-pack__reels" aria-label="{{ section_title ? section_title : 'Influencer reels' }}">
        <div class="influencer-pack__reels-head">
          <button
            type="button"
            class="influencer-pack__nav influencer-pack__nav--prev"
            aria-label="{{ trans('common.actions.previous')|default('Previous reel') }}">
            <i class="sicon-keyboard_arrow_left"></i>
          </button>
          <button
            type="button"
            class="influencer-pack__nav influencer-pack__nav--next"
            aria-label="{{ trans('common.actions.next')|default('Next reel') }}">
            <i class="sicon-keyboard_arrow_right"></i>
          </button>
        </div>

        <div class="influencer-pack__reels-track" tabindex="0" aria-label="{{ trans('common.messages.scroll')|default('Scrollable reels') }}">
          {% for reel in reels %}
            {% set video_mode = reel.video_mode|default('external') %}
            {% if video_mode is iterable %}
              {% set video_mode = video_mode|first|default('external') %}
            {% endif %}
            {% set reel_cta_url = reel.cta_url|default('') %}
            {% if reel_cta_url is iterable %}
              {% set reel_cta_item = reel_cta_url|first %}
              {% if reel_cta_item is iterable %}
                {% set reel_cta_url = reel_cta_item.value|default('') %}
              {% else %}
                {% set reel_cta_url = reel_cta_item|default('') %}
              {% endif %}
            {% endif %}
            {% set has_external_video = video_mode == 'external' and reel.video_url %}
            {% set has_youtube_video = video_mode == 'youtube' and reel.youtube_id %}
            {% set has_media = has_external_video or has_youtube_video or reel.poster %}
            {% set reel_creator_name = reel.creator_name|default('') %}
            {% set reel_caption = reel.caption|default('') %}
            {% set reel_alt = reel_caption ? reel_caption : (reel_creator_name ? reel_creator_name : 'Reel preview') %}
            <article
              class="influencer-pack__reel-card"
              data-index="{{ loop.index0 }}"
              data-mode="{{ video_mode }}"
              data-has-external="{{ has_external_video ? 'true' : 'false' }}"
              data-has-youtube="{{ has_youtube_video ? 'true' : 'false' }}">
              <div class="influencer-pack__reel-media">
                {% if reel.poster %}
                  <img
                    class="influencer-pack__poster"
                    src="{{ reel.poster }}"
                    alt="{{ reel_alt }}"
                    loading="{{ loop.index <= 2 ? 'eager' : 'lazy' }}">
                {% endif %}

                {% if has_external_video %}
                  <video
                    class="influencer-pack__video"
                    playsinline
                    preload="none"
                    poster="{{ reel.poster }}"
                    {{ muted_enabled ? 'muted' : '' }}>
                    <source src="{{ reel.video_url }}">
                  </video>
                {% elseif has_youtube_video %}
                  <div class="influencer-pack__youtube" hidden>
                    <lite-youtube videoid="{{ reel.youtube_id }}" params="rel=0"></lite-youtube>
                  </div>
                {% endif %}

                <div class="influencer-pack__reel-top">
                  {% if reel_creator_name %}
                    <span class="influencer-pack__reel-creator">{{ reel_creator_name }}</span>
                  {% endif %}
                  {% if reel.promo_code %}
                    <span class="influencer-pack__code-group">
                      <span class="influencer-pack__reel-code" dir="ltr">{{ reel.promo_code }}</span>
                      <button type="button" class="influencer-pack__copy-code" data-code="{{ reel.promo_code|e('html_attr') }}">{{ copy_button_text }}</button>
                    </span>
                  {% endif %}
                </div>

                <div class="influencer-pack__reel-bottom{{ has_external_video ? ' has-mute' : '' }}">
                  {% if has_external_video %}
                    <button
                      type="button"
                      class="influencer-pack__mute-toggle"
                      aria-pressed="{{ muted_enabled ? 'true' : 'false' }}"
                      aria-label="{{ muted_enabled ? 'تشغيل الصوت' : 'كتم الصوت' }}"
                      data-label-muted="تشغيل الصوت"
                      data-label-unmuted="كتم الصوت">
                      <span>{{ muted_enabled ? 'تشغيل الصوت' : 'كتم الصوت' }}</span>
                    </button>
                  {% endif %}
                  <button
                    type="button"
                    class="influencer-pack__play-toggle"
                    aria-label="{{ trans('common.actions.play')|default('Play reel') }}"
                    {{ has_media ? '' : 'disabled' }}>
                    <i class="sicon-play2"></i>
                  </button>
                  <div class="influencer-pack__progress" aria-hidden="true">
                    <span class="influencer-pack__progress-fill"></span>
                  </div>
                  {% if reel.cta_text and reel_cta_url %}
                    <a href="{{ reel_cta_url }}" class="influencer-pack__cta">{{ reel.cta_text }}</a>
                  {% endif %}
                </div>
              </div>

              {% if reel_caption %}
                <p class="influencer-pack__caption">{{ reel_caption }}</p>
              {% endif %}

              {% if not has_external_video and not has_youtube_video and reel.cta_text and reel_cta_url %}
                <a href="{{ reel_cta_url }}" class="influencer-pack__cta influencer-pack__cta--fallback">{{ reel.cta_text }}</a>
              {% endif %}
            </article>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    {% if show_promo_blocks %}
      <section class="influencer-pack__promos" aria-label="{{ promo_aria_label }}">
        {% for promo in promo_blocks %}
          {% set promo_cta_url = promo.cta_url|default('') %}
          {% if promo_cta_url is iterable %}
            {% set promo_cta_item = promo_cta_url|first %}
            {% if promo_cta_item is iterable %}
              {% set promo_cta_url = promo_cta_item.value|default('') %}
            {% else %}
              {% set promo_cta_url = promo_cta_item|default('') %}
            {% endif %}
          {% endif %}
          <article class="influencer-pack__promo">
            <div class="influencer-pack__promo-head">
              {% if promo.title %}
                <h3 class="influencer-pack__promo-title">{{ promo.title }}</h3>
              {% endif %}
              {% if promo.code %}
                <span class="influencer-pack__code-group influencer-pack__code-group--promo">
                  <p class="influencer-pack__promo-code" dir="ltr">{{ promo.code }}</p>
                  <button type="button" class="influencer-pack__copy-code" data-code="{{ promo.code|e('html_attr') }}">{{ copy_button_text }}</button>
                </span>
              {% endif %}
            </div>
            {% if promo.description %}
              <p class="influencer-pack__promo-description">{{ promo.description }}</p>
            {% endif %}
            {% if promo.cta_text and promo_cta_url %}
              <a href="{{ promo_cta_url }}" class="influencer-pack__promo-link">{{ promo.cta_text }}</a>
            {% endif %}
          </article>
        {% endfor %}
      </section>
    {% endif %}

    {% if show_picked_products %}
      <section class="influencer-pack__products">
        {% set picked_products_title = component.picked_products_title|default('') %}
        {% set picked_limit = picked_products|length %}
        {% if picked_limit > 12 %}
          {% set picked_limit = 12 %}
        {% endif %}
        {% if picked_products_title %}
          <div class="s-block__title influencer-pack__products-title">
            <div class="right-side">
              <h2>{{ picked_products_title }}</h2>
            </div>
          </div>
        {% endif %}
        <salla-products-slider
          source="selected"
          source-value="[{{ picked_products|map((product) => product.id)|join(',') }}]"
          limit="{{ picked_limit }}"
          slider-id="influencer-pack-products-{{ position }}"
          block-title=" ">
        </salla-products-slider>
      </section>
    {% endif %}
  </div>
</section>
